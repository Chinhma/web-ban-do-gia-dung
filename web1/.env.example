# Copy this file to .env and fill values for local development
# Then run: copy .env.example .env  (Windows) or cp .env.example .env (Unix)

# Django secret (keep private in production)
SECRET_KEY=django-insecure-change-me

# Debug
DEBUG=True

# Email (SMTP) - set DJANGO_EMAIL_BACKEND to smtp to send real emails
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
